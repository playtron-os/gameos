FROM registry.playtron.one/internal/playtronos:1.3-stable-base

# Set OS version
COPY rootfs/usr/lib/os-release-playtron /usr/lib/

# Update packages
RUN dnf5 -y upgrade \
  grid-1.36.3 \
  playserve-1.25.0 \
  playtron-plugin-local-1.6.0 \
  SteamBus-1.27.5

# Clear cache.
RUN dnf5 clean all && \
  rm -r -f \
    /boot/.vmlinuz*.hmac \
    /var/cache/*

# View final packages.
RUN rpm -qa | sort

# View how well we adhere to bootc best practices.
RUN bootc container lint --no-truncate
