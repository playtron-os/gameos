FROM registry.playtron.one/internal/playtronos:1.2-stable-base

# Set OS version
COPY rootfs/usr/lib/os-release-playtron /usr/lib/

# Increased open file limits to (1) match the system service and (2) to fix gamescope-dbus issues
COPY rootfs/usr/lib/systemd/user/dbus-broker.service.d/50-playtron.conf			/usr/lib/systemd/user/dbus-broker.service.d/

# Add powerstation support for the Claw Tempest Edition
COPY rootfs/usr/lib/udev/hwdb.d/60-powerstation-autostart.hwdb                         /usr/lib/udev/hwdb.d/

# Update packages
RUN dnf5 -y upgrade \
  gamescope-dbus-1.13.1 \
  grid-1.36.1 \
  inputplumber-0.75.2 \
  plugin-egs-1.2.4 \
  plugin-gog-1.1.2 \
  playserve-1.24.1 \
  powerstation-0.8.1 \
  SteamBus-1.27.3

# Prevent systemd from showing an end-of-life message after boot.
RUN sed -i '/SUPPORT_END=.*/d' /usr/lib/os-release

# Clear cache.
RUN dnf5 clean all && \
  rm -r -f \
    /boot/.vmlinuz*.hmac \
    /var/cache/*

# View final packages.
RUN rpm -qa | sort

# View how well we adhere to bootc best practices.
RUN bootc container lint --no-truncate
